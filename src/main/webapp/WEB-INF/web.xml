<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>IPLive</display-name>
    <listener>
        <listener-class>com.iplive.util.AppContextListener</listener-class>
    </listener>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Servlet Mappings -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.iplive.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.iplive.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.iplive.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.iplive.servlet.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MatchServlet</servlet-name>
        <servlet-class>com.iplive.servlet.MatchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MatchServlet</servlet-name>
        <url-pattern>/match</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BallServlet</servlet-name>
        <servlet-class>com.iplive.servlet.BallServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BallServlet</servlet-name>
        <url-pattern>/nextball</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ScorecardServlet</servlet-name>
        <servlet-class>com.iplive.servlet.ScorecardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScorecardServlet</servlet-name>
        <url-pattern>/scorecard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StatsServlet</servlet-name>
        <servlet-class>com.iplive.servlet.StatsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StatsServlet</servlet-name>
        <url-pattern>/stats</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SquadsServlet</servlet-name>
        <servlet-class>com.iplive.servlet.SquadsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SquadsServlet</servlet-name>
        <url-pattern>/squads</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HistoryServlet</servlet-name>
        <servlet-class>com.iplive.servlet.HistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HistoryServlet</servlet-name>
        <url-pattern>/history</url-pattern>
    </servlet-mapping>

    <servlet>
    <servlet-name>PlayerServlet</servlet-name>
    <servlet-class>com.iplive.servlet.PlayerServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>PlayerServlet</servlet-name>
    <url-pattern>/player</url-pattern>
</servlet-mapping>

    <servlet>
        <servlet-name>FantasyServlet</servlet-name>
        <servlet-class>com.iplive.servlet.FantasyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FantasyServlet</servlet-name>
        <url-pattern>/fantasy</url-pattern>
    </servlet-mapping>

</web-app>
